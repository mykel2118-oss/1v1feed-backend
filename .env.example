# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/1v1feed

# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Authentication
JWT_SECRET=your-super-secret-jwt-key-here-change-in-production
BETTER_AUTH_SECRET=your-better-auth-secret-here-change-in-production

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:8081,http://localhost:3001

# File Storage (Local)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600

# Video Configuration
MAX_VIDEO_DURATION=10
ALLOWED_VIDEO_FORMATS=mp4,mov,webm

# Email Configuration (Optional - for future use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# API Configuration
API_BASE_URL=http://localhost:3000
